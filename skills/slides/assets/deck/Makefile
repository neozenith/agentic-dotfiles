# {{DECK_NAME}} slide deck (Marp). Generated by the `slides` skill.
#
# Self-contained: this folder needs nothing from parent directories, and nothing
# from the skill that made it. The Marp CLI is pulled on demand via `bunx`, so
# there is no install step and no committed node_modules.
#
# Media pipeline: Marp renders per-slide PNG frames natively (--images png) ->
# scripts/slide_durations.py computes how long each slide holds from its readable
# word count -> ffmpeg concat-demuxer stitches an mp4 with per-slide durations ->
# ffmpeg two-pass palette -> GIF. No Playwright needed; Marp emits the frames.
#
# Override anything at the CLI:  make gif WPM=220 SLIDE_MAX=8 MARP_VERSION=4.4.0

.DEFAULT_GOAL := help

MARP_VERSION ?= 4.4.0
# `bunx --yes` fetches + runs the pinned CLI with no global install (needs network
# to npm on first run, then bun caches it).
MARP         ?= bunx --yes @marp-team/marp-cli@$(MARP_VERSION)

# `?=` so any target can run against another deck in this folder:
#   make html DECK=master-template.md NAME=master-template
# `make template` (below) is that override, named. Every rule keys off these two,
# so a second deck needs no rules of its own.
DECK   ?= slides.md
NAME   ?= {{DECK_NAME}}
THEME  := themes/{{DECK_NAME}}.css
OUTDIR := build
PUBDIR := ../assets
TIERS  := tiers.toml

# Every per-deck artifact is namespaced by $(NAME). Frames especially: a shared
# build/frames/ lets one deck's PNGs sit behind a stamp another deck then treats
# as its own, which silently produces a GIF of the wrong deck.
FRAMES := $(OUTDIR)/frames/$(NAME)
VIDEO  := $(OUTDIR)/$(NAME).mp4
GIF    := $(OUTDIR)/$(NAME).gif
DURATIONS := $(OUTDIR)/$(NAME)-durations.concat

DURSCRIPT  := scripts/slide_durations.py
TIERSCRIPT := scripts/tier_progress.py
PROSESCRIPT := scripts/prose_check.py
PORT   ?= 8080

# Per-slide timing: dwell = clamp(READ_BASE + words / WPM * 60, SLIDE_MIN, SLIDE_MAX).
WPM        ?= 260
READ_BASE  ?= 1.0
SLIDE_MIN  ?= 2
SLIDE_MAX  ?= 7

# Reading-speed PROFILES: (wpm, base, min, max). `make variants` builds a suffixed
# mp4+gif per profile from ONE frame render, so pacings compare side by side.
PROFILES        := readable punchy teaser
DEFAULT_PROFILE := punchy

readable_WPM  := 180
readable_BASE := 1.2
readable_MIN  := 2.5
readable_MAX  := 12

punchy_WPM  := 260
punchy_BASE := 1.0
punchy_MIN  := 2
punchy_MAX  := 7

teaser_WPM  := 340
teaser_BASE := 0.8
teaser_MIN  := 1.5
teaser_MAX  := 5

FPS        ?= 30
GIF_FPS    ?= 2
GIF_HEIGHT ?= 720

MARP_FLAGS := --theme-set $(THEME) --allow-local-files

# Mermaid: each assets/<name>.md is a diagram source. Marp has no Mermaid runtime,
# so mmdc pre-renders it to assets/<name>-1.png (it appends the fence index).
MMDC     ?= npx -p @mermaid-js/mermaid-cli mmdc
MMD_SRC  := $(wildcard assets/*.md)
MMD_PNG  := $(MMD_SRC:.md=-1.png)
# Committed SVGs the deck embeds. Deck INPUTS: without this dependency the frame
# stamp ignores an edited diagram and ships stale PNGs.
SVG_SRC  := $(wildcard assets/*.svg)

.PHONY: help html pdf pptx pptx-editable diagrams frames durations video gif variants \
        watch serve preview clean version all publish progress progress-check prose ci \
        template template-check

# ---- Tier progress bar: PARSE-TIME sync ----------------------------------
# The bar is DERIVED from the deck's `@tier` markers, so no build may render a bar
# that lies about where you are.
#
# The sync MUST happen at parse time, not as a prerequisite. GNU make caches file
# timestamps: a recipe that rewrites $(DECK) mid-run is invisible to rules that
# already stat'd it, so `frames` would keep serving PNGs of the pre-retune deck.
# `$(shell ...)` runs before make evaluates the DAG, so every rule below stats the
# already-synced deck. Do not "simplify" this into a prerequisite.
#
# Skipped for goals that do not render (and for `make` with no goal = help), so
# listing help or cleaning never rewrites a source file.
NOSYNC_GOALS := help clean version progress-check template-check prose ci
ifneq (,$(strip $(MAKECMDGOALS)))
ifeq (,$(filter $(NOSYNC_GOALS),$(MAKECMDGOALS)))
PROGRESS_SYNC := $(shell uv run $(TIERSCRIPT) --deck $(DECK) --tiers $(TIERS) 2>&1 || echo TIER_PROGRESS_FAILED)
ifneq (,$(findstring TIER_PROGRESS_FAILED,$(PROGRESS_SYNC)))
$(error tier progress sync failed, the deck's @tier markers are invalid:$(subst TIER_PROGRESS_FAILED,,$(PROGRESS_SYNC)))
endif
endif
endif

progress: ## Regenerate the tier progress bar from the @tier markers (writes the deck)
	uv run $(TIERSCRIPT) --deck $(DECK) --tiers $(TIERS)

progress-check: ## Verify the generated bar matches the @tier markers (writes nothing)
	uv run $(TIERSCRIPT) --deck $(DECK) --tiers $(TIERS) --check

template-check: ## Verify the reference deck's bar is current (writes nothing)
	uv run $(TIERSCRIPT) --deck master-template.md --tiers $(TIERS) --check

prose: ## Check authored prose (no em-dash, Australian spelling, inclusive terms)
	uv run $(PROSESCRIPT)

ci: progress-check template-check prose ## Free, deterministic gate: bars current, prose clean
	@echo "ci: ok"

help: ## Show this help
	@grep -hE '^[a-zA-Z0-9_-]+:.*?## ' $(MAKEFILE_LIST) \
		| awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-14s\033[0m %s\n", $$1, $$2}'

html: $(OUTDIR) diagrams ## Build a self-contained HTML deck
	$(MARP) $(MARP_FLAGS) $(DECK) -o $(OUTDIR)/$(NAME).html

pdf: $(OUTDIR) diagrams ## Build a PDF (needs Chrome/Chromium)
	$(MARP) $(MARP_FLAGS) --pdf $(DECK) -o $(OUTDIR)/$(NAME).pdf

# Raster PPTX: each slide is a high-DPI bitmap. PPTX_SCALE multiplies the base
# 1280x720 canvas: 4x => 5120x2880, so the deck stays crisp projected full-screen.
PPTX_SCALE ?= 4

pptx: $(OUTDIR) diagrams ## Build a raster PowerPoint deck at PPTX_SCALE (needs Chrome/Chromium)
	$(MARP) $(MARP_FLAGS) --pptx --image-scale $(PPTX_SCALE) $(DECK) -o $(OUTDIR)/$(NAME).pptx

pptx-editable: $(OUTDIR) diagrams ## Build an editable/vector PPTX (needs Chrome/Chromium + LibreOffice)
	@command -v soffice >/dev/null 2>&1 \
		|| { echo "error: LibreOffice 'soffice' is required for --pptx-editable (brew install --cask libreoffice)"; exit 1; }
	$(MARP) $(MARP_FLAGS) --pptx --pptx-editable $(DECK) -o $(OUTDIR)/$(NAME)-editable.pptx

diagrams: $(MMD_PNG) ## Render every Mermaid source in assets/*.md to PNG (needs Chrome/Chromium)

assets/%-1.png: assets/%.md
	$(MMDC) -i $< -o assets/$*.png --scale 4 -e png -t dark -b transparent

# Frames are gated behind a stamp so Marp renders ONCE even when three variants are
# built in a row. The deck is already tier-synced at parse time, so its mtime here
# is final: no phony prerequisite is needed, and none may be added (a .PHONY prereq
# counts as perpetually newer and would defeat the stamp).
FRAMES_STAMP := $(FRAMES)/.stamp

$(FRAMES_STAMP): $(DECK) $(MMD_PNG) $(SVG_SRC)
	rm -rf $(FRAMES)
	mkdir -p $(FRAMES)
	$(MARP) $(MARP_FLAGS) --images png --image-scale 2 $(DECK) -o $(FRAMES)/slide.png
	@touch $@

frames: $(FRAMES_STAMP) ## Render one high-DPI PNG per slide (needs Chrome/Chromium)

durations: $(FRAMES_STAMP) ## Compute each slide's hold duration into the concat playlist
	uv run $(DURSCRIPT) --deck $(DECK) --frames-dir $(FRAMES) --out $(DURATIONS) \
	  --wpm $(WPM) --base $(READ_BASE) --min $(SLIDE_MIN) --max $(SLIDE_MAX)

video: durations ## Stitch the frames into an mp4, each slide held for its computed duration
	@command -v ffmpeg >/dev/null 2>&1 || { echo "error: ffmpeg is required (brew install ffmpeg)"; exit 1; }
	# concat demuxer replays each frame for its `duration`; the fps filter resamples
	# that variable timeline to a constant $(FPS). -safe 0: the playlist is absolute.
	ffmpeg -y -f concat -safe 0 -i $(DURATIONS) \
	  -vf "scale=1280:-2:flags=lanczos,format=yuv420p,fps=$(FPS)" -movflags +faststart $(VIDEO)
	@echo "wrote $(VIDEO)"

gif: video ## Convert the deck video into a shareable GIF
	@command -v ffmpeg >/dev/null 2>&1 || { echo "error: ffmpeg is required"; exit 1; }
	ffmpeg -y -i $(VIDEO) \
	  -vf "fps=$(GIF_FPS),scale=-1:$(GIF_HEIGHT):flags=lanczos,palettegen=stats_mode=diff" \
	  $(OUTDIR)/$(NAME)-palette.png
	ffmpeg -y -i $(VIDEO) -i $(OUTDIR)/$(NAME)-palette.png \
	  -lavfi "fps=$(GIF_FPS),scale=-1:$(GIF_HEIGHT):flags=lanczos[x];[x][1:v]paletteuse=dither=bayer" \
	  $(GIF)
	@echo "wrote $(GIF)"

# ---- Reading-speed variants ----------------------------------------------
# Pattern rules keyed on profile name. `$($*_WPM)` is a computed variable lookup:
# $* expands to the profile, then <profile>_WPM resolves to its value.

$(OUTDIR)/$(NAME)-durations-%.concat: $(FRAMES_STAMP)
	uv run $(DURSCRIPT) --deck $(DECK) --frames-dir $(FRAMES) --out $@ \
	  --wpm $($*_WPM) --base $($*_BASE) --min $($*_MIN) --max $($*_MAX)

video-%: $(OUTDIR)/$(NAME)-durations-%.concat ## Build the mp4 for profile % (readable|punchy|teaser)
	@command -v ffmpeg >/dev/null 2>&1 || { echo "error: ffmpeg is required"; exit 1; }
	@stem=$(NAME)-$*-$($*_WPM); \
	 ffmpeg -y -f concat -safe 0 -i $< \
	   -vf "scale=1280:-2:flags=lanczos,format=yuv420p,fps=$(FPS)" -movflags +faststart $(OUTDIR)/$$stem.mp4; \
	 echo "wrote $(OUTDIR)/$$stem.mp4"

gif-%: video-% ## Build the GIF for profile % (readable|punchy|teaser)
	@command -v ffmpeg >/dev/null 2>&1 || { echo "error: ffmpeg is required"; exit 1; }
	@stem=$(NAME)-$*-$($*_WPM); \
	 ffmpeg -y -i $(OUTDIR)/$$stem.mp4 \
	   -vf "fps=$(GIF_FPS),scale=-1:$(GIF_HEIGHT):flags=lanczos,palettegen=stats_mode=diff" $(OUTDIR)/$(NAME)-palette-$*.png; \
	 ffmpeg -y -i $(OUTDIR)/$$stem.mp4 -i $(OUTDIR)/$(NAME)-palette-$*.png \
	   -lavfi "fps=$(GIF_FPS),scale=-1:$(GIF_HEIGHT):flags=lanczos[x];[x][1:v]paletteuse=dither=bayer" $(OUTDIR)/$$stem.gif; \
	 echo "wrote $(OUTDIR)/$$stem.gif"

variants: $(addprefix gif-,$(PROFILES)) ## Build all reading-speed variant GIFs

VARIANT_GIFS := $(foreach p,$(PROFILES),$(OUTDIR)/$(NAME)-$(p)-$($(p)_WPM).gif)
CANON_GIF    := $(OUTDIR)/$(NAME)-$(DEFAULT_PROFILE)-$($(DEFAULT_PROFILE)_WPM).gif

publish: html pdf variants ## Publish html, pdf, variant GIFs + the canonical GIF to $(PUBDIR)
	mkdir -p $(PUBDIR)
	cp $(OUTDIR)/$(NAME).html $(OUTDIR)/$(NAME).pdf $(PUBDIR)/
	cp $(VARIANT_GIFS) $(PUBDIR)/
	cp $(CANON_GIF) $(PUBDIR)/$(NAME).gif
	@echo "published -> $(PUBDIR)/"

all: publish pptx pptx-editable ## Build everything and publish the shareable assets

# The layout/style reference deck. A sub-make (not a variable override in this
# rule) because DECK is read at PARSE time by the tier sync above: a recipe-level
# override would sync slides.md and then render master-template.md.
template: ## Build the layout reference deck and open it (master-template.md)
	@$(MAKE) --no-print-directory preview DECK=master-template.md NAME=master-template

watch: $(OUTDIR) diagrams ## Rebuild HTML on every save
	$(MARP) $(MARP_FLAGS) --watch $(DECK) -o $(OUTDIR)/$(NAME).html

serve: ## Live preview server with hot reload (open the printed URL)
	$(MARP) $(MARP_FLAGS) --server --port $(PORT) .

preview: html ## Build HTML then open it in the default browser
	@command -v open >/dev/null 2>&1 && open $(OUTDIR)/$(NAME).html \
		|| echo "Built $(OUTDIR)/$(NAME).html. Open it in a browser."

version: ## Print the Marp CLI version this deck builds with
	$(MARP) --version

clean: ## Remove build artifacts (build/ + generated diagram PNGs)
	rm -rf $(OUTDIR)
	rm -f $(MMD_PNG)

$(OUTDIR):
	mkdir -p $(OUTDIR)
